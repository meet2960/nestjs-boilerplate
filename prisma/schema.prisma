  users_complaints_modified_byTousers users?    @relation("complaints_modified_byTousers", fields: [modified_by], references: [user_id], onUpdate: NoAction, map: "complaints_modified_by_fk")
  users_complaints_resolved_byTousers users?    @relation("complaints_resolved_byTousers", fields: [resolved_by], references: [user_id], onUpdate: NoAction, map: "complaints_resolved_by_fk")
}

