generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model common_lists {
  common_list_id                        Int            @id(map: "common_lists_pk") @default(autoincrement())
  table_name                            String         @db.VarChar(255)
  display_text                          String         @db.VarChar(255)
  value_text                            String         @db.VarChar(1000)
  parent_common_list_id                 Int?
  sort_order                            Int
  status                                String         @db.VarChar(100)
  info_1                                String?        @db.VarChar(500)
  info_2                                String?        @db.VarChar(500)
  info_3                                String?        @db.VarChar(100)
  info_4                                String?        @db.VarChar(100)
  created_by                            Int?
  created_date                          DateTime       @db.Timestamptz(6)
  modified_by                           Int?
  modified_date                         DateTime?      @db.Timestamptz(6)
  users_common_lists_created_byTousers  users?         @relation("common_lists_created_byTousers", fields: [created_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "common_lists_created_by_fk")
  users_common_lists_modified_byTousers users?         @relation("common_lists_modified_byTousers", fields: [modified_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "common_lists_modified_by_fk")
