  title                               String    @db.VarChar(100)
  description                         String?
  category                            String    @db.VarChar(100)
  status                              String    @db.VarChar(100)
  priority                            String    @db.VarChar(100)
  attachment_id                       Int?
  assigned_to                         Int?
  resolved_by                         Int?
  resolved_date                       DateTime? @db.Timestamptz(6)
  resolved_remarks                    String?   @db.VarChar(500)
  response_message                    String?
  is_escalated                        Boolean?  @default(false)
  created_by                          Int
  created_date                        DateTime  @default(now()) @db.Timestamptz(6)
  modified_by                         Int?
  modified_date                       DateTime? @db.Timestamptz(6)
  users_complaints_assigned_toTousers users?    @relation("complaints_assigned_toTousers", fields: [assigned_to], references: [user_id], onUpdate: NoAction, map: "complaints_assigned_to_fk")
